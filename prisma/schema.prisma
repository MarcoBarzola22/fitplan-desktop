  generator client {
    provider = "prisma-client-js"
  }

  datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
  }

  // --- BIBLIOTECA DE EJERCICIOS ---

  model Pattern {
    id        Int        @id @default(autoincrement())
    name      String     @unique // Ej: "Tracción", "Empuje", "Pierna"
    exercises Exercise[]
  }

 model Exercise {
    id        Int      @id @default(autoincrement())
    name      String
    videoUrl  String?
    pattern   Pattern  @relation(fields: [patternId], references: [id])
    patternId Int
    isWarmup  Boolean  @default(false)
    createdAt DateTime @default(now())

    
    routineItems RoutineItem[]
    warmupItems  WarmupItem[] 
  }

  // --- CONSTRUCTOR DE RUTINAS ---

  model Routine {
    id         Int      @id @default(autoincrement())
    clientName String
    daysCount  Int
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
    clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

    days RoutineDay[]
  }

  model RoutineDay {
    id        Int     @id @default(autoincrement())
    dayNumber Int
    routineId Int
    routine   Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)

    // Separación clara en la DB
    exercises RoutineItem[]
    warmups   WarmupItem[] // <--- Relación para los calentamientos
  }

  // Para los ejercicios principales de la tabla
  model RoutineItem {
    id     Int     @id @default(autoincrement())
    sets   String?
    reps   String?
    rest   String?
    weight String?
    rpe    String?
    order  Int     @default(0) // Para mantener el orden que elija el usuario

    dayId      Int
    day        RoutineDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
    exerciseId Int
    exercise   Exercise   @relation(fields: [exerciseId], references: [id])
  }

  // Para la sección azul de Calentamiento/Movilidad
  model WarmupItem {
    id     Int     @id @default(autoincrement())
    sets   String?
    reps   String?
    weight String?
    order  Int     @default(0)

    dayId      Int
    day        RoutineDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
    exerciseId Int
    exercise   Exercise   @relation(fields: [exerciseId], references: [id])
  }

// --- NUEVOS MODELOS V2 ---

model Client {
  id        String    @id @default(uuid())
  name      String
  phone     String?   
  email     String?
  
  // --- Datos Biométricos (Nuevos) ---
  age       Int?      // Edad en años
  weight    Float?    // Peso en kg (Float permite decimales, ej: 75.5)
  height    Float?    // Altura en cm (ej: 180)
  
  isActive  Boolean   @default(true) 
  
  // Relaciones
  routines  Routine[] 
  payments  Payment[] 

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Payment {
  id          String    @id @default(uuid())
  amount      Float
  paymentDate DateTime  @default(now())
  validUntil  DateTime  // Para saber cuándo se le vence el mes
  notes       String?
  
  // Relación con el Cliente
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}